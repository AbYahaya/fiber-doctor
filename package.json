{
  "name": "fiber-doctor",
  "version": "0.1.0",
  "description": "Diagnostic CLI for Fiber Network nodes",
  "type": "module",
  "bin": {
    "fiber-doctor": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "ui:dev": "npm --prefix web run dev",
    "ui:build": "npm --prefix web run build",
    "ui:start": "npm --prefix web run start"
  },
  "keywords": [
    "fiber",
    "ckb",
    "cli",
    "diagnostics"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^15.0.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
